# ---------------------------------------------------------------------------
# UAE Fleet Management System — environment configuration
# Copy to .env and adjust. Everything is environment-driven.
# ---------------------------------------------------------------------------

# --- Database ---
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet_password
POSTGRES_DB=fleet_management
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full URL consumed by Prisma. In docker-compose the host is `db`.
DATABASE_URL=postgresql://fleet:fleet_password@localhost:5432/fleet_management?schema=public

# --- Backend server ---
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:5173
# Single-service deploy (e.g. Railway): absolute path to the built SPA to serve
# from the API process. Leave empty for local dev (Vite serves the frontend).
STATIC_DIR=

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=10

# --- File storage abstraction (local | s3) ---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# When STORAGE_DRIVER=s3 (S3-compatible; UAE region friendly)
S3_ENDPOINT=
S3_REGION=me-central-1
S3_BUCKET=fleet-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true
# Upload guards
UPLOAD_MAX_SIZE_MB=15
UPLOAD_ALLOWED_MIME=application/pdf,image/png,image/jpeg,image/webp

# --- Notifications (pluggable channels) ---
# EmailChannel via SMTP. WhatsAppChannel is stubbed behind FEATURE_WHATSAPP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Fleet Management <no-reply@fleet.local>"
# If true, emails are logged to console instead of sent (dev)
EMAIL_DRY_RUN=true

# --- Feature flags ---
FEATURE_INVENTORY=false
FEATURE_WHATSAPP=false

# --- Alert engine ---
# Daily evaluation schedule (cron). Default 06:00 Asia/Dubai.
ALERT_CRON=0 6 * * *
TZ=Asia/Dubai

# --- Locale defaults ---
DEFAULT_CURRENCY=AED
DEFAULT_LOCALE=en

# --- Rate limiting (auth endpoints) ---
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=20

# --- Seed admin (used by seed script) ---
SEED_ADMIN_EMAIL=admin@fleet.local
SEED_ADMIN_PASSWORD=Admin@123
